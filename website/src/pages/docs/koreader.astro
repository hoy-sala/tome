import DocsMeta from '../../components/DocsMeta.astro'
import Callout from '../../components/Callout.astro'
import Steps from '../../components/Steps.astro'
import Kbd from '../../components/Kbd.astro'
import { Tabs } from '../../components/Tabs'
import { ThemedShot } from '../../components/ThemedShot'
import fs from 'node:fs'
import path from 'node:path'
import { withBase } from '../../lib/path'
const syncFlowSvg = fs.readFileSync(path.resolve(process.cwd(), 'public/diagrams/sync-flow.svg'), 'utf-8')

const unixSnippet    = 'cd ~/.koreader/plugins\ncp ~/Downloads/tomesync.koplugin.zip .\nunzip tomesync.koplugin.zip'
