---
// OG card preview — mocks how `og.png` will render when the link is dropped
// into iMessage, Slack, Discord, and X. Internal page, not linked.
import BaseLayout from '../layouts/BaseLayout.astro'
import SiteHeader from '../components/SiteHeader.astro'

const TITLE = 'Tome — A self-hosted ebook library that knows how you read'
const DESCRIPTION = 'A self-hosted ebook library that knows how you read.'
const URL = 'tome.bndct.sh'
const IMG = '/og.png'
---
<BaseLayout title="OG preview — internal">
  <SiteHeader />
  <main class="max-w-5xl mx-auto px-6 pt-32 pb-24">
    <div class="mb-12">
      <p class="text-xs uppercase tracking-widest text-[var(--muted)] mb-2">Internal</p>
      <h1 class="text-3xl font-bold mb-3">OG card preview</h1>
      <p class="text-[var(--muted)] max-w-2xl">
        How the link will look when shared. Real chrome from each platform, our actual <code>og.png</code> sitting inside.
        These are local mockups, not live previews — once it's deployed you can test the real thing at
        <a href="https://www.opengraph.xyz" class="text-[var(--accent)] underline" target="_blank">opengraph.xyz</a>.
      </p>
    </div>

    <!-- raw image -->
    <section class="mb-16">
      <h2 class="text-lg font-bold mb-4">Raw image (1200×630)</h2>
      <img src={IMG} alt="OG card" class="w-full rounded-xl border border-[var(--border)]" />
    </section>

    <!-- iMessage -->
    <section class="mb-16">
      <h2 class="text-lg font-bold mb-1">iMessage</h2>
      <p class="text-sm text-[var(--muted)] mb-4">Big image preview, title + domain below.</p>
      <div class="bg-[#1c1c1e] rounded-2xl p-6 max-w-md mx-auto">
        <div class="bg-[#2c2c2e] rounded-2xl overflow-hidden">
          <img src={IMG} alt="" class="w-full block" />
          <div class="px-3 py-2 border-t border-black/30">
            <div class="text-white text-[13px] leading-tight font-medium">{TITLE}</div>
            <div class="text-white/60 text-[11px] mt-0.5">{URL}</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Slack -->
    <section class="mb-16">
      <h2 class="text-lg font-bold mb-1">Slack (unfurl)</h2>
      <p class="text-sm text-[var(--muted)] mb-4">Vertical left bar + title + description + image.</p>
      <div class="bg-white rounded-md p-4 max-w-2xl border border-gray-200 text-black">
        <div class="text-[15px] text-[#1264a3] font-medium mb-1">benedict <span class="text-[#616061] text-[12px] ml-1">3:14 PM</span></div>
        <div class="text-[15px] mb-2">Check this out — <span class="text-[#1264a3]">https://{URL}</span></div>
        <div class="border-l-4 border-gray-300 pl-3 py-1">
          <div class="text-[13px] text-[#616061] font-medium mb-0.5">Tome</div>
          <div class="text-[15px] font-bold text-[#1264a3] mb-0.5 leading-tight">{TITLE}</div>
          <div class="text-[13px] text-[#1d1c1d] mb-2">{DESCRIPTION}</div>
          <img src={IMG} alt="" class="max-w-[500px] w-full rounded border border-gray-200" />
        </div>
      </div>
    </section>

    <!-- Discord -->
    <section class="mb-16">
      <h2 class="text-lg font-bold mb-1">Discord</h2>
      <p class="text-sm text-[var(--muted)] mb-4">Coloured embed with title, description, and image below.</p>
      <div class="bg-[#36393f] rounded-md p-4 max-w-xl">
        <div class="text-[#dcddde] text-[15px] mb-2">https://{URL}</div>
        <div class="rounded-md overflow-hidden bg-[#2f3136] border-l-4 border-[#8a353c]">
          <div class="p-3">
            <div class="text-[#b9bbbe] text-[12px] mb-1">Tome</div>
            <div class="text-white text-[16px] font-semibold mb-1 leading-tight">{TITLE}</div>
            <div class="text-[#dcddde] text-[14px] mb-3">{DESCRIPTION}</div>
            <img src={IMG} alt="" class="max-w-[400px] w-full rounded" />
          </div>
        </div>
      </div>
    </section>

    <!-- X / Twitter -->
    <section class="mb-16">
      <h2 class="text-lg font-bold mb-1">X / Twitter (summary_large_image)</h2>
      <p class="text-sm text-[var(--muted)] mb-4">Image dominates, title + domain overlay at the bottom.</p>
      <div class="bg-black rounded-2xl p-6 max-w-xl">
        <div class="text-white text-[15px] mb-3">
          Just self-hosted my ebook library with this — <span class="text-[#1d9bf0]">tome.bndct.sh</span>
        </div>
        <div class="relative rounded-2xl overflow-hidden border border-[#2f3336]">
          <img src={IMG} alt="" class="w-full block" />
          <div class="absolute bottom-3 left-3 bg-black/80 backdrop-blur-sm px-2 py-1 rounded text-white text-[13px]">
            {URL}
          </div>
        </div>
      </div>
    </section>

    <div class="text-sm text-[var(--muted)] text-center pt-8">
      <a href="/" class="hover:text-[var(--fg)] transition-colors">← back to landing</a>
    </div>
  </main>
</BaseLayout>
