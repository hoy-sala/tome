---
// Shared top header used by both the landing page and the docs.
// Highlights the active section based on the current URL.
import ThemeToggle from './ThemeToggle.astro'
import Logo from './Logo.astro'
import { SearchBox } from './SearchBox'
import { withBase, stripBase } from '../lib/path'
const path = stripBase(Astro.url.pathname)
const isDocs = path.startsWith('/docs')
const isWhy = path === '/why' || path === '/why/'
const isBlog = path.startsWith('/blog')

const navLinks = [
  { href: withBase('/why'), label: 'Why Tome?', active: isWhy },
  { href: withBase('/blog'), label: 'Blog', active: isBlog },
  { href: withBase('/docs'), label: 'Docs', active: isDocs },
  { href: 'https://github.com/bndct-devops/tome', label: 'GitHub', active: false, external: true },
]
---
<header class="fixed top-0 inset-x-0 z-50 backdrop-blur-md bg-[var(--bg)]/70 border-b border-[var(--border)]">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href={withBase('/')} class="flex items-center gap-2.5 font-semibold text-lg">
      <Logo />
      Tome
    </a>
    <nav class="flex items-center gap-3 md:gap-5">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`text-sm transition-colors hidden sm:inline ${link.active ? 'text-[var(--fg)] font-medium' : 'text-[var(--muted)] hover:text-[var(--fg)]'}`}
        >{link.label}</a>
      ))}
      <SearchBox client:idle />
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        class="sm:hidden flex items-center justify-center w-9 h-9 rounded-lg hover:bg-[var(--card)] transition-colors"
        aria-label="Menu"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
          <line x1="2" y1="4" x2="16" y2="4" />
          <line x1="2" y1="9" x2="16" y2="9" />
          <line x1="2" y1="14" x2="16" y2="14" />
        </svg>
      </button>
    </nav>
  </div>
  <div id="mobile-menu" class="sm:hidden hidden border-t border-[var(--border)] bg-[var(--bg)]/95 backdrop-blur-md">
    <div class="max-w-6xl mx-auto px-6 py-3 flex flex-col gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`text-sm py-2.5 px-3 rounded-lg transition-colors ${link.active ? 'text-[var(--fg)] font-medium bg-[var(--accent-soft)]' : 'text-[var(--muted)] hover:text-[var(--fg)] hover:bg-[var(--card)]'}`}
        >{link.label}</a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden')
    })
    document.addEventListener('click', (e) => {
      if (!btn.contains(e.target as Node) && !menu.contains(e.target as Node)) {
        menu.classList.add('hidden')
      }
    })
  }
</script>
